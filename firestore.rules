rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - streakCount: number (optional)
    //   - lastActivityDate: timestamp (optional)
    //   - badges: list (optional)
    //   - favorites: list (optional)
    //   - contacts: list (optional)
    //
    // Collection: checkins
    // Document ID: {checkinId}
    // Fields:
    //   - senderId: string (required)
    //   - senderName: string (required)
    //   - receiverId: string (required)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: ["healthy", "needs_attention"])
    //   - read: bool (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('streakCount' in data) || data.streakCount is number) &&
             (!('badges' in data) || data.badges is list) &&
             (!('favorites' in data) || data.favorites is list);
    }

    function isValidCheckIn(data) {
      return data.keys().hasAll(['senderId', 'senderName', 'receiverId', 'timestamp', 'status']) &&
             data.senderId is string &&
             data.senderName is string &&
             data.receiverId is string &&
             data.timestamp is timestamp &&
             data.status in ["healthy", "needs_attention"] &&
             (!('location' in data) || (data.location is map && data.location.latitude is number && data.location.longitude is number));
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated(); 
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /checkins/{checkinId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && isValidCheckIn(request.resource.data);
      allow update: if isAuthenticated() && resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
